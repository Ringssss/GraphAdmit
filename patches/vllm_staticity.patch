+def _staticity_tokens_in_policy_ranges(num_tokens: int, ranges) -> bool | None:
+    if not isinstance(ranges, list):
+        return None
+    matched_any = False
+    for item in ranges:
+        if not isinstance(item, dict):
+            continue
+        bounds = _staticity_range_bounds(item)
+        if bounds is None:
+            continue
+        lo, hi = bounds
+        template_tokens = item.get("template_tokens")
+        try:
+            if template_tokens is not None and int(num_tokens) == int(template_tokens):
+                return True
+        except (TypeError, ValueError):
+            pass
+        matched_any = True
+        if lo < int(num_tokens) <= hi:
+            return True
+    if matched_any:
+        return False
+    return None
