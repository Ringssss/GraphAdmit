+def _staticity_env_int_or_none(name: str) -> int | None:
+    raw = os.environ.get(name)
+    if raw is None or raw == "":
+        return None
+    try:
+        return int(raw)
+    except ValueError:
+        return None
+
+
+def _staticity_tokens_in_policy_ranges(
+    num_tokens: int,
+    ranges,
+) -> bool | None:
+    if not isinstance(ranges, list):
+        return None
+    matched_any = False
+    for item in ranges:
+        if not isinstance(item, dict):
+            continue
+        try:
+            lo = int(item.get('lo', item.get('low', -1)))
+            hi = int(item.get('hi', item.get('high', 2**63 - 1)))
+        except (TypeError, ValueError):
+            continue
+        matched_any = True
+        template_tokens = item.get('template_tokens')
+        try:
+            if template_tokens is not None and int(num_tokens) == int(
+                    template_tokens):
+                return True
+        except (TypeError, ValueError):
+            pass
+        if lo < int(num_tokens) <= hi:
+            return True
+    if matched_any:
+        return False
+    return None
+
+
+def _staticity_policy_rule_for_tokens(num_tokens: int):
+    policy = _staticity_load_runtime_policy_for_arena() or {}
+    rules = policy.get('rules', [])
+    normalized_rules = []
+    if isinstance(rules, list):
+        normalized_rules = [rule for rule in rules if isinstance(rule, dict)]
+    elif isinstance(rules, dict):
+        for range_name, body in rules.items():
+            if not isinstance(body, dict) or ',' not in str(range_name):
+                continue
+            try:
+                left, right = str(range_name).strip().split(',', 1)
+                lo = int(left.strip().lstrip('(').lstrip('['))
+                hi = int(right.strip().rstrip(']').rstrip(')'))
+            except (TypeError, ValueError):
+                continue
+            rule = dict(body)
+            rule.setdefault('lo', lo)
+            rule.setdefault('hi', hi)
+            normalized_rules.append(rule)
+    for rule in normalized_rules:
+        try:
+            lo = int(rule.get('lo', rule.get('low', -1)))
+            hi = int(rule.get('hi', rule.get('high', 2**63 - 1)))
+        except (TypeError, ValueError):
+            continue
+        if lo < int(num_tokens) <= hi:
+            return rule
+    return None
+
+
+def _staticity_token_axis_template_tokens(num_tokens: int) -> int | None:
+    if not _staticity_fixed_metadata_arena_enabled():
+        return None
+    rule = _staticity_policy_rule_for_tokens(num_tokens)
+    if not isinstance(rule, dict):
+        return None
+    raw = rule.get('template_tokens')
+    if raw is None:
+        return None
+    try:
+        template_tokens = int(raw)
+    except (TypeError, ValueError):
+        return None
+    if template_tokens <= 0 or template_tokens < int(num_tokens):
+        return None
+    return template_tokens
+
+
+def _staticity_fixed_metadata_arena_active_for_tokens(num_tokens: int) -> bool:
+    if not _staticity_fixed_metadata_arena_enabled():
+        return False
+    if not _staticity_fixed_metadata_arena_allowed_in_current_forward():
+        return False
+    policy = _staticity_load_runtime_policy_for_arena() or {}
+    range_admission = _staticity_tokens_in_policy_ranges(
+        num_tokens,
+        policy.get('fixed_metadata_arena_ranges'),
+    )
+    if range_admission is not None:
+        return range_admission
+    min_tokens = _staticity_env_int_or_none(
+        'STATICITY_VLLM_FIXED_METADATA_ARENA_MIN_TOKENS')
+    max_tokens = _staticity_env_int_or_none(
+        'STATICITY_VLLM_FIXED_METADATA_ARENA_MAX_TOKENS')
+    if min_tokens is None and policy.get('fixed_metadata_arena_min_tokens') is not None:
+        try:
+            min_tokens = int(policy.get('fixed_metadata_arena_min_tokens'))
+        except (TypeError, ValueError):
+            min_tokens = None
+    if max_tokens is None and policy.get('fixed_metadata_arena_max_tokens') is not None:
+        try:
+            max_tokens = int(policy.get('fixed_metadata_arena_max_tokens'))
+        except (TypeError, ValueError):
+            max_tokens = None
+    if min_tokens is not None and int(num_tokens) <= min_tokens:
+        return False
+    if max_tokens is not None and int(num_tokens) > max_tokens:
+        return False
+    return True
+
+
+def _staticity_fixed_metadata_arena_max_reqs(
+    requested: int,
+    hard_limit: int,
+) -> int:
+    raw = os.environ.get('STATICITY_VLLM_FIXED_METADATA_ARENA_MAX_REQS')
+    if raw:
+        try:
+            target = int(raw)
+        except ValueError:
+            target = hard_limit
+    else:
+        target = hard_limit
+    target = min(max(1, target), hard_limit)
+    return min(max(requested, target), hard_limit)
