+def _staticity_profile_attention_metadata(**fields):
+    path = os.environ.get('STATICITY_VLLM_ATTN_PROFILE')
+    if not path:
+        return
+    tensors = []
+    for name, tensor in fields.pop('tensors', {}).items():
+        record = _staticity_tensor_record(name, tensor)
+        if record is not None:
+            tensors.append(record)
+    out = Path(path)
+    out.parent.mkdir(parents=True, exist_ok=True)
+    with out.open('a', encoding='utf-8') as f:
+        f.write(json.dumps({
+            'ts': time.time(),
+            'component': 'attention_metadata',
+            **fields,
+            'tensors': tensors,
+        }, sort_keys=True) + '\n')
+
+def _staticity_profile_event(event: dict):
+    path = os.environ.get('STATICITY_VLLM_RUNNER_PROFILE')
+    if not path:
+        return
+    out = Path(path)
+    out.parent.mkdir(parents=True, exist_ok=True)
+    with out.open('a', encoding='utf-8') as f:
+        f.write(json.dumps({'ts': time.time(), **event}, sort_keys=True) + '\n')
+
+
+def _staticity_env_bool(name: str, default: bool = False) -> bool:
+    value = os.environ.get(name)
+    if value is None:
+        return default
+    return value.lower() in ('1', 'true', 'yes', 'on')
+
+
+def _staticity_fixed_metadata_arena_enabled() -> bool:
+    return _staticity_env_bool('STATICITY_VLLM_FIXED_METADATA_ARENA')
+
+
+def _staticity_fixed_metadata_arena_allowed_in_current_forward() -> bool:
+    if _staticity_env_bool(
+        'STATICITY_VLLM_ARENA_ON_FALLBACK',
+        False,
+    ):
+        return True
+    try:
+        forward_context = get_forward_context()
+    except Exception:
+        return True
+    if forward_context is None:
+        return True
+    return forward_context.cudagraph_runtime_mode != CUDAGraphMode.NONE
