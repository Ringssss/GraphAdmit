+def _staticity_range_bounds(item) -> tuple[int, int] | None:
+    try:
+        lo_raw = item.get("lo", item.get("low", -1))
+        hi_raw = item.get("hi", item.get("high", 2**63 - 1))
+        return int(lo_raw), int(hi_raw)
+    except (AttributeError, TypeError, ValueError):
+        return None
