+def _staticity_load_runtime_policy_for_arena():
+    global _STATICITY_ARENA_POLICY_CACHE, _STATICITY_ARENA_POLICY_PATH
+    path = os.environ.get('STATICITY_VLLM_RUNTIME_POLICY')
+    if not path:
+        return None
+    if (
+        _STATICITY_ARENA_POLICY_CACHE is not None
+        and _STATICITY_ARENA_POLICY_PATH == path
+    ):
+        return _STATICITY_ARENA_POLICY_CACHE
+    try:
+        with open(path, encoding='utf-8') as policy_file:
+            data = json.load(policy_file)
+    except Exception:
+        _STATICITY_ARENA_POLICY_CACHE = None
+        _STATICITY_ARENA_POLICY_PATH = path
+        return None
+    _STATICITY_ARENA_POLICY_CACHE = data.get('runtime_policy', data)
+    _STATICITY_ARENA_POLICY_PATH = path
+    return _STATICITY_ARENA_POLICY_CACHE
+
