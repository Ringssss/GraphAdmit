+        hi = matched_rule.get("hi", matched_rule.get("high", "*"))
+        template_tokens = matched_rule.get("template_tokens")
+        if template_tokens is not None:
+            if _staticity_exact_token_templates():
+                return (
+                    f"{chosen_action}:{lo}:{hi}:"
+                    f"tokens={int(num_tokens)}:"
+                    f"template={template_tokens}:reqs={req_part}"
+                )
+            return (
+                f"{chosen_action}:{lo}:{hi}:"
+                f"template={template_tokens}:reqs={req_part}"
+            )
+        return (
+            f"{chosen_action}:"
+            f"{lo}:"
+            f"{hi}:"
+            f"reqs={req_part}"
+        )
+    return f"{chosen_action}:default:{int(num_tokens)}:reqs={req_part}"
+
+
+def _staticity_rule_template_tokens(matched_rule) -> int | None:
+    if not isinstance(matched_rule, dict):
+        return None
+    raw = matched_rule.get("template_tokens")
+    if raw is None:
+        return None
+    try:
+        value = int(raw)
+    except (TypeError, ValueError):
+        return None
+    return value if value > 0 else None
+
+
+def _staticity_normalize_rules(policy: dict) -> list[dict]:
+    raw_rules = policy.get("rules", [])
+    if isinstance(raw_rules, list):
+        return [rule for rule in raw_rules if isinstance(rule, dict)]
+    if not isinstance(raw_rules, dict):
+        return []
+    rules: list[dict] = []
+    for range_name, body in raw_rules.items():
+        if not isinstance(body, dict):
+            continue
+        if "," not in str(range_name):
+            continue
+        try:
+            left, right = str(range_name).strip().split(",", 1)
+            lo = int(left.strip().lstrip("(").lstrip("["))
+            hi = int(right.strip().rstrip("]").rstrip(")"))
+        except (TypeError, ValueError):
+            continue
+        rule = dict(body)
+        rule.setdefault("lo", lo)
+        rule.setdefault("hi", hi)
+        rules.append(rule)
+    return rules
+
+
+def _staticity_record_template(template_id: str, field: str) -> dict:
+    stats = _STATICITY_RUNTIME_TEMPLATE_STATS.setdefault(
+        template_id,
+        {"attempts": 0, "admitted": 0, "rejected": 0},
+    )
+    stats[field] = stats.get(field, 0) + 1
+    return stats
+
+
+def _staticity_template_aliases(template_id: str, matched_rule) -> list[str]:
+    aliases: list[str] = []
+    aliases.append(str(template_id))
+    template_tokens = _staticity_rule_template_tokens(matched_rule)
+    if template_tokens is not None:
+        aliases.append(f"tokens={template_tokens}")
+    return aliases
+
+
+def _staticity_evict_template(
+    template_id: str,
+    aliases: list[str],
+    reason: str,
+    *,
+    disable: bool = False,
+) -> None:
+    for item in [str(template_id), *[str(alias) for alias in aliases]]:
+        _STATICITY_RUNTIME_ADMITTED_TEMPLATES.discard(item)
+        stats = _STATICITY_RUNTIME_TEMPLATE_STATS.get(item)
+        if stats is None:
+            continue
+        stats["live_evictions"] = int(stats.get("live_evictions", 0) or 0) + 1
+        stats["live_last_evict_reason"] = reason
+        if disable:
+            stats["live_disabled"] = True
+            stats["live_disable_reason"] = reason
+
+
+def _staticity_trust_seeded_online_admission() -> bool:
+    # Offline residual-capture policies may contain historical latency samples.
+    # Those samples are useful for analysis but must not become user-visible
+    # online admission evidence unless explicitly requested for debugging.
+    return _staticity_bool_env(
+        "STATICITY_VLLM_TRUST_SEEDED_ONLINE_ADMISSION", False)
+
+
+def _staticity_seed_live_template_stats(policy) -> None:
+    if not _staticity_trust_seeded_online_admission():
+        return
+    if not isinstance(policy, dict):
+        return
+    online = policy.get("online_admission")
+    if not isinstance(online, dict):
+        return
+    for item in online.get("templates") or []:
+        if not isinstance(item, dict):
+            continue
+        template_id = item.get("template_id")
+        if template_id is None:
+            continue
+        stats = _STATICITY_RUNTIME_TEMPLATE_STATS.setdefault(
+            str(template_id),
+            {"attempts": 0, "admitted": 0, "rejected": 0},
+        )
+        stats.update({
+            "live_samples": int(item.get("samples", 0) or 0),
+            "live_useful": int(item.get("useful", 0) or 0),
+            "live_regressions": int(item.get("regressions", 0) or 0),
+            "live_correctness_failures": int(item.get("correctness_failures", 0) or 0),
+            "live_saving_ewma_ms": item.get("saving_ewma_ms"),
+            "live_p95_regression_ms": item.get("p95_regression_ms"),
+            "live_disabled": bool(item.get("disabled", False)),
+            "live_disable_reason": item.get("disable_reason"),
+            "live_seeded": True,
+        })
+
+
+def _staticity_live_cfg(policy) -> dict:
+    online = policy.get("online_admission", {}) if isinstance(policy, dict) else {}
+    if not isinstance(online, dict):
+        online = {}
+    live_cfg = policy.get("live_admission", {}) if isinstance(policy, dict) else {}
+    if not isinstance(live_cfg, dict):
+        live_cfg = {}
+    return {
+        "enabled": (
+            os.environ.get("STATICITY_VLLM_LIVE_ADMISSION", "0") == "1"
+            or bool(live_cfg.get("enabled", False))
+            or online.get("mode") == "online_self_learning_admission"
+        ),
+        "min_samples": int(live_cfg.get(
+            "min_samples",
+            online.get("min_samples", _staticity_env_int("STATICITY_VLLM_LIVE_MIN_SAMPLES", 0)),
+        ) or 0),
+        "min_useful_rate": float(live_cfg.get(
+            "min_useful_rate",
+            online.get("min_useful_rate", _staticity_env_float("STATICITY_VLLM_LIVE_MIN_USEFUL_RATE", 0.0)),
+        ) or 0.0),
+        "min_saving_ms": float(live_cfg.get(
+            "min_saving_ms",
+            online.get("min_saving_ms", _staticity_env_float("STATICITY_VLLM_LIVE_MIN_SAVING_MS", 0.0)),
+        ) or 0.0),
+        "max_p95_regression_ms": float(live_cfg.get(
+            "max_p95_regression_ms",
+            online.get("max_p95_regression_ms", _staticity_env_float("STATICITY_VLLM_LIVE_MAX_P95_REGRESSION_MS", 1.0e9)),
+        ) or 1.0e9),
+        "max_correctness_failures": int(live_cfg.get(
+            "max_correctness_failures",
+            online.get("max_correctness_failures", _staticity_env_int("STATICITY_VLLM_LIVE_MAX_CORRECTNESS_FAILURES", 0)),
+        ) or 0),
+        "explore_until_min_samples": bool(live_cfg.get(
+            "explore_until_min_samples",
+            os.environ.get("STATICITY_VLLM_LIVE_EXPLORE", "0") == "1",
+        )),
+    }
+
+
+def _staticity_runtime_lazy_capture_enabled(policy) -> bool:
+    if _staticity_bool_env("STATICITY_VLLM_LIVE_CAPTURE", False):
+        return True
+    live_capture = policy.get("live_capture", {}) if isinstance(policy, dict) else {}
+    if isinstance(live_capture, dict) and live_capture.get("enabled"):
+        return True
+    residual = policy.get("residual_capture", {}) if isinstance(policy, dict) else {}
+    if isinstance(residual, dict) and residual.get("mode") in {
+        "same_engine_live_capture",
+        "same_engine_lazy_capture",
+    }:
+        return True
+    return False
+
+
+def _staticity_live_explore_replay_enabled() -> bool:
+    # Exploration must be fail-closed by default: until a candidate template
+    # has correctness and latency evidence, it may be measured by the harness
+    # but must not serve user-visible graph output.
+    return _staticity_control_bool(
+        "unsafe_live_explore_replay",
+        "STATICITY_VLLM_UNSAFE_LIVE_EXPLORE_REPLAY",
+        False,
+    )
+
+
+def _staticity_force_runtime_fallback_enabled() -> bool:
+    # Used by same-engine validation: run the same prompt through the normal
+    # runtime engine, but force GraphAdmit-owned extra templates to fallback so
+    # the fallback timing is not silently satisfied by a previously captured
+    # candidate graph.
+    return _staticity_control_bool(
+        "force_runtime_fallback",
+        "STATICITY_VLLM_FORCE_RUNTIME_FALLBACK",
+        False,
+    )
+
+
+def _staticity_graphadmit_only_enabled(policy=None) -> bool:
+    return (
+        _staticity_bool_env("STATICITY_VLLM_GRAPHADMIT_ONLY", False)
+        or bool(
+            isinstance(policy, dict)
+            and policy.get("single_engine_graphadmit_only", False)
+        )
+    )
+
+
+def _staticity_live_capture_only_enabled(policy) -> bool:
+    return (
+        _staticity_runtime_lazy_capture_enabled(policy)
+        and _staticity_bool_env("STATICITY_VLLM_LIVE_CAPTURE_ONLY_EXPLORE", False)
+    )
+
+
+def _staticity_replay_guard_key(
+    mode: CUDAGraphMode,
+    batch_descriptor: BatchDescriptor,
+) -> tuple[str, BatchDescriptor]:
+    return (mode.name, batch_descriptor)
+
+
+def _staticity_mark_replay_guard(
+    mode: CUDAGraphMode,
+    batch_descriptor: BatchDescriptor,
+    admission,
+) -> None:
+    key = _staticity_replay_guard_key(mode, batch_descriptor)
+    block = (
+        isinstance(admission, dict)
+        and bool(admission.get("live_capture_only", False))
+        and not bool(admission.get("live_replay_allowed", False))
+    )
+    if block:
+        _STATICITY_LIVE_REPLAY_BLOCKED.add(key)
+    else:
+        _STATICITY_LIVE_REPLAY_BLOCKED.discard(key)
+
+
+def _staticity_cudagraph_replay_allowed(
+    mode: CUDAGraphMode,
+    batch_descriptor: BatchDescriptor,
+) -> bool:
+    return _staticity_replay_guard_key(mode, batch_descriptor) not in (
+        _STATICITY_LIVE_REPLAY_BLOCKED
+    )
+
+
+def _staticity_lazy_capture_desc(
+    mode: CUDAGraphMode,
+    desc: BatchDescriptor,
+    policy,
+) -> bool:
+    if not _staticity_runtime_lazy_capture_enabled(policy):
+        return False
+    try:
+        base_capture_size = int(policy.get(
+            "single_engine_base_capture_size",
+            _staticity_runtime_base_capture_size(),
+        ) or 512)
+    except (AttributeError, TypeError, ValueError):
+        base_capture_size = _staticity_runtime_base_capture_size()
+    if int(desc.num_tokens) <= base_capture_size:
+        return False
+    # Residual live-capture templates are explored lazily.  They must not be
+    # captured at startup in either PIECEWISE or FULL decode mode; otherwise a
+    # fail-closed policy still pays graph memory/warmup for unadmitted templates.
+    if mode == CUDAGraphMode.FULL:
+        return True
+    if mode != CUDAGraphMode.PIECEWISE:
+        return False
+    for rule in _staticity_normalize_rules(policy if isinstance(policy, dict) else {}):
+        action = str(rule.get("action", policy.get("default_action", "default")))
+        if action not in {"ours", "ours_cp"}:
+            continue
+        try:
+            if int(rule.get("template_tokens", 0)) == int(desc.num_tokens):
+                return True
+        except (TypeError, ValueError):
+            continue
+    residual = policy.get("residual_capture", {}) if isinstance(policy, dict) else {}
+    if isinstance(residual, dict):
+        for value in residual.get("extra_capture_sizes") or []:
+            try:
+                if int(value) == int(desc.num_tokens):
+                    return True
+            except (TypeError, ValueError):
+                continue
+    return False
+
+
+def _staticity_should_start_lazy_capture(
+    policy,
+    matched_rule,
+    template_id: str,
+    action: str | None,
+    admission: dict,
+) -> bool:
+    if not _staticity_runtime_lazy_capture_enabled(policy):
+        return False
+    if action not in {"ours", "ours_cp"}:
+        return False
+    cfg = _staticity_live_cfg(policy)
+    if not cfg["enabled"] or not cfg["explore_until_min_samples"]:
+        return False
+    aliases = _staticity_template_aliases(template_id, matched_rule)
+    samples = 0
+    disabled = False
+    for alias in aliases:
+        stats = _STATICITY_RUNTIME_TEMPLATE_STATS.get(alias)
+        if stats is None:
+            continue
+        samples = max(samples, int(stats.get("live_samples", 0) or 0))
+        disabled = disabled or bool(stats.get("live_disabled", False))
+    admission["live_capture"] = True
+    admission["lazy_capture_samples"] = samples
+    if disabled:
+        admission["lazy_capture_reject_reason"] = "live_disabled"
+        return False
+    return samples < int(cfg["min_samples"])
+
+
+def _staticity_padded_descriptor(
+    num_tokens: int,
+    uniform_decode: bool,
+    has_lora: bool,
+    num_active_loras: int,
+    max_num_seqs: int,
+    uniform_decode_query_len: int,
+    bs_to_padded_graph_size: list[int],
+) -> BatchDescriptor:
+    num_tokens_padded = bs_to_padded_graph_size[num_tokens]
+    if uniform_decode:
+        num_reqs = min(num_tokens_padded // uniform_decode_query_len, max_num_seqs)
+    else:
+        num_reqs = None
+    return BatchDescriptor(
+        num_tokens=num_tokens_padded,
+        num_reqs=num_reqs,
+        uniform=uniform_decode,
+        has_lora=has_lora,
+        num_active_loras=num_active_loras,
+    )
+
+
+def _staticity_live_update_stats(template_id: str, obs: dict) -> None:
+    source = str(obs.get("source", ""))
+    correct = bool(obs.get("correct", obs.get("token_correct", True)))
+    trusted_positive_source = source in {
+        "live_graph_replay",
+        "trusted_live_graph_replay",
+    }
+    trusted_negative_source = source in {
+        "graph_replay_shadow",
+        "live_graph_replay",
+        "trusted_live_graph_replay",
+    }
+    trust_all = _staticity_bool_env("STATICITY_VLLM_TRUST_LIVE_OBSERVATIONS", False)
+    trust_shadow_positive = _staticity_bool_env(
+        "STATICITY_VLLM_TRUST_SHADOW_POSITIVE_OBSERVATIONS", False)
+    if correct and not (
+        trusted_positive_source
+        or trust_all
+        or (source == "graph_replay_shadow" and trust_shadow_positive)
+    ):
+        return
+    if not correct and not (
+        trusted_negative_source
+        or bool(obs.get("trusted_graph_replay", False))
+        or trust_all
+    ):
+        return
+    stats = _STATICITY_RUNTIME_TEMPLATE_STATS.setdefault(
+        str(template_id),
+        {"attempts": 0, "admitted": 0, "rejected": 0},
+    )
+    samples = int(stats.get("live_samples", 0) or 0) + 1
+    graph_ms = obs.get("graph_ms", obs.get("candidate_ms", obs.get("latency_ms")))
+    fallback_ms = obs.get("fallback_ms", obs.get("baseline_ms"))
+    try:
+        graph_ms_f = float(graph_ms)
+        fallback_ms_f = float(fallback_ms)
+    except (TypeError, ValueError):
+        return
+    delta = graph_ms_f - fallback_ms_f
+    useful = correct and delta < 0.0
+    alpha = _staticity_env_float("STATICITY_VLLM_LIVE_EWMA_ALPHA", 0.35)
+    old_saving = stats.get("live_saving_ewma_ms")
+    saving = fallback_ms_f - graph_ms_f
+    if old_saving is None:
+        saving_ewma = saving
+    else:
+        try:
+            saving_ewma = alpha * saving + (1.0 - alpha) * float(old_saving)
+        except (TypeError, ValueError):
+            saving_ewma = saving
+    regressions = int(stats.get("live_regressions", 0) or 0) + int(correct and delta >= 0.0)
+    p95_reg = stats.get("live_p95_regression_ms")
+    if correct and delta >= 0.0:
+        try:
+            p95_reg = max(float(p95_reg or 0.0), float(delta))
+        except (TypeError, ValueError):
+            p95_reg = float(delta)
+    stats.update({
+        "live_samples": samples,
+        "live_useful": int(stats.get("live_useful", 0) or 0) + int(useful),
+        "live_regressions": regressions,
+        "live_correctness_failures": int(stats.get("live_correctness_failures", 0) or 0) + int(not correct),
+        "live_saving_ewma_ms": saving_ewma,
+        "live_p95_regression_ms": p95_reg,
+    })
+    if not correct:
+        stats["live_disabled"] = True
+        stats["live_disable_reason"] = "live_correctness_failure"
+
+
+def _staticity_ingest_live_observations(policy) -> None:
+    global _STATICITY_LIVE_OBS_PATH, _STATICITY_LIVE_OBS_OFFSET
+    if not _staticity_live_cfg(policy)["enabled"]:
+        return
+    path = os.environ.get("STATICITY_VLLM_LIVE_OBSERVATIONS")
+    if not path:
+        return
+    if path != _STATICITY_LIVE_OBS_PATH:
+        _STATICITY_LIVE_OBS_PATH = path
+        _STATICITY_LIVE_OBS_OFFSET = 0
+    try:
+        with open(path, "r", encoding="utf-8") as fp:
+            fp.seek(_STATICITY_LIVE_OBS_OFFSET)
+            lines = fp.readlines()
+            _STATICITY_LIVE_OBS_OFFSET = fp.tell()
+    except FileNotFoundError:
+        return
+    except Exception:
+        logger.debug("Failed to ingest staticity live observations", exc_info=True)
+        return
+    for line in lines:
+        if not line.strip():
+            continue
+        try:
+            obs = json.loads(line)
+        except json.JSONDecodeError:
+            continue
+        template_ids = []
+        template_id = obs.get("template_id")
+        if template_id is not None:
+            template_ids.append(str(template_id))
+        correct = bool(obs.get("correct", obs.get("token_correct", True)))
+        expand_positive_aliases = _staticity_bool_env(
+            "STATICITY_VLLM_POSITIVE_ALIAS_EXPANSION", False)
+        if (not correct) or expand_positive_aliases:
+            aliases = obs.get("template_aliases")
+            if isinstance(aliases, list):
+                for alias in aliases:
+                    if alias is not None:
+                        template_ids.append(str(alias))
+        seen = set()
+        for item in template_ids:
+            if item in seen:
+                continue
+            seen.add(item)
+            _staticity_live_update_stats(item, obs)
+
+
+def _staticity_live_allows(
+    policy,
+    template_id: str,
+    matched_rule,
+    admission: dict,
+) -> tuple[bool, str | None]:
+    cfg = _staticity_live_cfg(policy)
+    if not cfg["enabled"]:
+        return True, None
+    _staticity_ingest_live_observations(policy)
+    aliases = _staticity_template_aliases(template_id, matched_rule)
+    stats = None
+    for alias in aliases:
+        candidate = _STATICITY_RUNTIME_TEMPLATE_STATS.get(alias)
+        if candidate is not None and int(candidate.get("live_samples", 0) or 0) > 0:
+            stats = candidate
+            admission["live_template_alias"] = alias
+            break
+    if stats is None:
+        for alias in aliases:
+            if alias in _STATICITY_RUNTIME_TEMPLATE_STATS:
+                stats = _STATICITY_RUNTIME_TEMPLATE_STATS[alias]
+                admission["live_template_alias"] = alias
+                break
+    if stats is None:
+        stats = _STATICITY_RUNTIME_TEMPLATE_STATS.setdefault(
+            template_id,
+            {"attempts": 0, "admitted": 0, "rejected": 0},
+        )
+        admission["live_template_alias"] = template_id
+    samples = int(stats.get("live_samples", 0) or 0)
+    useful = int(stats.get("live_useful", 0) or 0)
+    correctness_failures = int(stats.get("live_correctness_failures", 0) or 0)
+    saving_ewma = stats.get("live_saving_ewma_ms")
+    p95_reg = stats.get("live_p95_regression_ms")
+    useful_rate = useful / samples if samples else 0.0
+    admission.update({
+        "live_admission": True,
+        "live_samples": samples,
+        "live_useful_rate": useful_rate,
+        "live_saving_ewma_ms": saving_ewma,
+        "live_p95_regression_ms": p95_reg,
+        "live_correctness_failures": correctness_failures,
+    })
+    if bool(stats.get("live_disabled", False)):
+        _staticity_evict_template(
+            template_id,
+            aliases,
+            stats.get("live_disable_reason") or "live_disabled",
+            disable=True,
+        )
+        return False, stats.get("live_disable_reason") or "live_disabled"
+    if correctness_failures > cfg["max_correctness_failures"]:
+        _staticity_evict_template(
+            template_id,
+            aliases,
+            "live_correctness_failure",
+            disable=True,
+        )
+        return False, "live_correctness_failure"
+    if samples < cfg["min_samples"]:
+        if cfg["explore_until_min_samples"]:
+            admission["live_reason"] = "explore_until_min_samples"
+            if _staticity_live_explore_replay_enabled():
+                admission["live_explore_replay"] = True
+                return True, None
+            if _staticity_live_capture_only_enabled(policy):
+                admission["live_capture_only"] = True
+                admission["live_replay_allowed"] = False
+                return True, "live_capture_only_until_admitted"
+            return False, "live_explore_fallback_until_admitted"
+        return False, f"live_samples_lt_{cfg['min_samples']}"
+    if useful_rate < cfg["min_useful_rate"]:
+        _staticity_evict_template(
+            template_id,
+            aliases,
+            "live_low_useful_rate",
+        )
+        return False, "live_low_useful_rate"
+    try:
+        if saving_ewma is None or float(saving_ewma) < cfg["min_saving_ms"]:
+            _staticity_evict_template(
+                template_id,
+                aliases,
+                "live_insufficient_latency_saving",
+            )
+            return False, "live_insufficient_latency_saving"
+    except (TypeError, ValueError):
+        return False, "live_insufficient_latency_saving"
+    try:
+        if p95_reg is not None and float(p95_reg) > cfg["max_p95_regression_ms"]:
+            _staticity_evict_template(
+                template_id,
+                aliases,
+                "live_tail_regression_guard",
+            )
+            return False, "live_tail_regression_guard"
+    except (TypeError, ValueError):
+        pass
+    admission["live_reason"] = "live_admitted"
+    admission["live_replay_allowed"] = True
+    return True, None
+
+
+def _staticity_runtime_allows_graph(
+    num_tokens: int,
+    num_reqs: int | None = None,
+    uniform_decode: bool = False,
+):
+    policy = _load_staticity_runtime_policy()
+    if not policy:
+        return True, None, None, None, None
+    default_action = policy.get("default_action", "default")
+    chosen_action = default_action
+    matched_rule = None
+    for rule in _staticity_normalize_rules(policy):
+        bounds = _staticity_range_bounds(rule)
+        if bounds is None:
+            continue
+        lo, hi = bounds
+        if lo < int(num_tokens) <= hi:
+            chosen_action = str(rule.get("action", default_action))
+            matched_rule = rule
